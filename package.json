{
  "name": "premier-electrical-group",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "npx tailwindcss -i ./src/css/styles.css -o ./dist/css/bundle.css --minify --content='./src/**/*.html, ./src/**/*.njk, ./src/**/*.js' && eleventy",
    "start": "concurrently \"npx tailwindcss -i ./src/css/styles.css -o ./dist/css/bundle.css --watch --content='./src/**/*.html, ./src/**/*.njk, ./src/**/*.js'\" \"eleventy --serve\"",
    "lint": "html-validate \"dist/**/*.html\"",
    "dev-deploy": "npm run build && npm run lint && node scripts.js dev",
    "prod-deploy": "npm run build && npm run lint && node scripts.js prod"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "type": "module",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@tailwindcss/cli": "^4.1.5",
    "concurrently": "^9.1.2",
    "html-validate": "^10.9.0",
    "tailwindcss": "^4.1.5"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "aos": "^2.3.4",
    "dotenv": "^17.2.3",
    "ftp-deploy": "^2.4.7",
    "sharp": "^0.34.5"
  }
}